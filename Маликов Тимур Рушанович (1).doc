}\cell\pard\intbl\itap1{\fs50\b \uc0\u1052 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1074  \uc0\u1058 \uc0\u1080 \uc0\u1084 \uc0\u1091 \uc0\u1088  \uc0\u1056 \uc0\u1091 \uc0\u1096 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1080 \uc0\u1095 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1052 \uc0\u1091 \uc0\u1078 \uc0\u1095 \uc0\u1080 \uc0\u1085 \uc0\u1072 , 29\uc0\u160 \uc0\u1083 \uc0\u1077 \uc0\u1090 , \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1083 \uc0\u1089 \uc0\u1103  28 \uc0\u1072 \uc0\u1074 \uc0\u1075 \uc0\u1091 \uc0\u1089 \uc0\u1090 \uc0\u1072  1996}\par\pard\intbl\sl260{\fs18 \par +7\uc0\u160 (917)\uc0\u160 2956296 {\cf1\emdash  \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1086 \uc0\u1095 \uc0\u1080 \uc0\u1090 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1073  \uc0\u1089 \uc0\u1074 \uc0\u1103 \uc0\u1079 \uc0\u1080 }\par {{\field{\*\fldinst HYPERLINK "mailto:mister.3151@mail.ru"}{\fldrslt\ul mister.3151@mail.ru}}}}\par\pard\intbl\sl260{\fs18 \par \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1078 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1077 \uc0\u1090 : \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1100 \par \uc0\u1043 \uc0\u1088 \uc0\u1072 \uc0\u1078 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 , \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1085 \uc0\u1072  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1091 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 \par \uc0\u1043 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1077 \uc0\u1079 \uc0\u1076 \uc0\u1091 , \uc0\u1085 \uc0\u1077  \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072 \uc0\u1084 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1072 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1083 \uc0\u1078 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1088 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1072 }\cell\row\trowd\cellx6861\clvertalt\cellx9638\pard\intbl\itap1\sa100\sl280{\fs24\b \uc0\u1042 \uc0\u1077 \uc0\u1076 \uc0\u1091 \uc0\u1097 \uc0\u1080 \uc0\u1081  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1082 }\pard\intbl\itap1\sl260{\fs18 \par{\uc0\u1057 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 :  }\par\li300{\uc0\u8212   \uc0\u1040 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1082 \par\uc0\u8212   \uc0\u1041 \uc0\u1080 \uc0\u1079 \uc0\u1085 \uc0\u1077 \uc0\u1089 -\uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1082 \par\uc0\u8212   \uc0\u1057 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1089 \uc0\u1090  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1081  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1078 \uc0\u1082 \uc0\u1080 }\par\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1058 \uc0\u1080 \uc0\u1087  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 : \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 \par \uc0\u1060 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1085 \uc0\u1072 \uc0\u160 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1077  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1103 \par \line\uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103  \uc0\u1074  \uc0\u1087 \uc0\u1091 \uc0\u1090 \uc0\u1080  \uc0\u1076 \uc0\u1086  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1085 \uc0\u1077  \uc0\u1080 \uc0\u1084 \uc0\u1077 \uc0\u1077 \uc0\u1090  \uc0\u1079 \uc0\u1085 \uc0\u1072 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }}\cell \pard\intbl\itap1\qr{\fs32\qc\b 150\uc0\u160 000\fs18\sl260  \uc0\u8381  \uc0\u1085 \uc0\u1072 \uc0\u160 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1080 }\par\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \emdash 5 \uc0\u1083 \uc0\u1077 \uc0\u1090  8 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1057 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u1100  2024 \emdash  \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1103 \uc0\u1097 \uc0\u1077 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103 \line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  7 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\pard\intbl\itap1\par\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1048 \uc0\u1085 \uc0\u1075 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 }\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1100 , www.ingos.ru}\par{\fs18 \uc0\u1060 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 }\par\li300{{\fs18 \uc0\u8226  \uc0\u1057 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }}\par \pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1042 \uc0\u1077 \uc0\u1076 \uc0\u1091 \uc0\u1097 \uc0\u1080 \uc0\u1081  \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1089 \uc0\u1090  \uc0\u1087 \uc0\u1086  \uc0\u1080 \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1084 \uc0\u1091  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1102 \par}\pard\intbl\itap1\sl260\sa60{\fs18 - \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072  \uc0\u1089  \uc0\u1079 \uc0\u1072 \uc0\u1103 \uc0\u1074 \uc0\u1082 \uc0\u1072 \uc0\u1084 \uc0\u1080  \uc0\u1085 \uc0\u1072  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  (\uc0\u1073 \uc0\u1072 \uc0\u1085 \uc0\u1082 \uc0\u1080 , \uc0\u1073 \uc0\u1088 \uc0\u1086 \uc0\u1082 \uc0\u1077 \uc0\u1088 \uc0\u1099 , \uc0\u1072 \uc0\u1075 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1099 , \uc0\u1079 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1081 \uc0\u1097 \uc0\u1080 \uc0\u1082 \uc0\u1080 , \uc0\u1087 \uc0\u1088 \uc0\u1103 \uc0\u1084 \uc0\u1099 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1080 ), \uc0\u1082 \uc0\u1086 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1086 \uc0\u1073 \uc0\u1098 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 ,, \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1081  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 ;{\line}- \uc0\u1089 \uc0\u1086 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1078 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1076 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1091 \uc0\u1102 \uc0\u1097 \uc0\u1080 \uc0\u1093  \uc0\u1076 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1074  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  (\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1085 \uc0\u1075 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 , \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072  \uc0\u1089  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1084 \uc0\u1080  \uc0\u1074  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1080 \uc0\u1086 \uc0\u1076  \uc0\u1076 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1074 );{\line}-\uc0\u1074 \uc0\u1079 \uc0\u1072 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1080 \uc0\u1077  \uc0\u1089  \uc0\u1089 \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1084 \uc0\u1080  \uc0\u1073 \uc0\u1072 \uc0\u1085 \uc0\u1082 \uc0\u1086 \uc0\u1074  \uc0\u1087 \uc0\u1086  \uc0\u1074 \uc0\u1086 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1072 \uc0\u1084  \uc0\u1080 \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 ;{\line}- \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1088 \uc0\u1072 \uc0\u1081 \uc0\u1090 \uc0\u1080 \uc0\u1085 \uc0\u1075  \uc0\u1088 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1074 , \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1085 \uc0\u1080 \uc0\u1084 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1099 \uc0\u1093  \uc0\u1085 \uc0\u1072  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 ;{\line}-\uc0\u1074 \uc0\u1079 \uc0\u1072 \uc0\u1080 \uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1086  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1084 \uc0\u1080  \uc0\u1087 \uc0\u1086 \uc0\u1076 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 \uc0\u1084 \uc0\u1080  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1080 ;{\line}-\uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1077 \uc0\u1090 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080  \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1081  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1077 .}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1048 \uc0\u1102 \uc0\u1085 \uc0\u1100  2023 \emdash  \uc0\u1057 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u1100  2024\line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  4 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1072 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1054 \uc0\u1054 \uc0\u1054  \uc0\u1057 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1073 \uc0\u1072 \uc0\u1085 \uc0\u1082  \uc0\u1057 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1046 \uc0\u1080 \uc0\u1079 \uc0\u1085 \uc0\u1080 }\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1100 , www.sovcombank.ru}\par{\fs18 \uc0\u1060 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 }\par\li300{{\fs18 \uc0\u8226  \uc0\u1057 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }}\par \pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1052 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1078 \uc0\u1077 \uc0\u1088  \uc0\u1072 \uc0\u1075 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1081  \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1087 \uc0\u1087 \uc0\u1099 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1056 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086  \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1087 \uc0\u1087 \uc0\u1086 \uc0\u1081  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1072 \uc0\u1075 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 ;{\line}\uc0\u1055 \uc0\u1086 \uc0\u1076 \uc0\u1073 \uc0\u1086 \uc0\u1088  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1072 \uc0\u1075 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 , \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 ;{\line}\uc0\u1052 \uc0\u1086 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1099  \uc0\u1085 \uc0\u1072  \uc0\u1074 \uc0\u1099 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 ;{\line}\uc0\u1050 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1100  \uc0\u1074 \uc0\u1099 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1075 \uc0\u1088 \uc0\u1091 \uc0\u1087 \uc0\u1087 \uc0\u1086 \uc0\u1081  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1087 \uc0\u1086 \uc0\u1082 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1081 ;{\line}\uc0\u1040 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079  \uc0\u1092 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1093  \uc0\u1087 \uc0\u1086 \uc0\u1082 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1081  \uc0\u1080  \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \uc0\u160 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1077 \uc0\u1090 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 .{\line}\uc0\u1054 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1076 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1074  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1089  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1084 \uc0\u1080   (\uc0\u1086 \uc0\u1073 \uc0\u1089 \uc0\u1083 \uc0\u1091 \uc0\u1078 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1074 \uc0\u1093 \uc0\u1086 \uc0\u1076 \uc0\u1103 \uc0\u1097 \uc0\u1077 \uc0\u1075 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1082 \uc0\u1072  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 );{\line}\uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1085 \uc0\u1075 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1074   \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 ;{\line}\uc0\u1050 \uc0\u1086 \uc0\u1085 \uc0\u1089 \uc0\u1091 \uc0\u1083 \uc0\u1100 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 ;{\line}\uc0\u1050 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1089 -\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1078 \uc0\u1080 ;}\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1060 \uc0\u1077 \uc0\u1074 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100  2022 \emdash  \uc0\u1048 \uc0\u1102 \uc0\u1085 \uc0\u1100  2023\line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  5 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1040 \uc0\u1054  \uc0\u1057 \uc0\u1050  "\uc0\u1055 \uc0\u1040 \uc0\u1056 \uc0\u1048 "}\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1053 \uc0\u1072 \uc0\u1073 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1078 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1063 \uc0\u1077 \uc0\u1083 \uc0\u1085 \uc0\u1099 }\par{\fs18 \uc0\u1060 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 }\par\li300{{\fs18 \uc0\u8226  \uc0\u1057 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }}\par \pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1057 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1089 \uc0\u1090  \uc0\u1087 \uc0\u1086  \uc0\u1080 \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1084 \uc0\u1091  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1102 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1047 \uc0\u1072 \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1086 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1080 \uc0\u1084 \uc0\u1091 \uc0\u1097 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1072 ;{\line}\uc0\u1047 \uc0\u1072 \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077   \uc0\u1076 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1074  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1053 \uc0\u1057  \uc0\u1080  \uc0\u1041 ;{\line}\uc0\u1047 \uc0\u1072 \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1076 \uc0\u1086 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1088 \uc0\u1086 \uc0\u1074  \uc0\u1080 \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 , \uc0\u1076 \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103   \uc0\u1090 \uc0\u1080 \uc0\u1090 \uc0\u1091 \uc0\u1083 \uc0\u1072  (\uc0\u1088 \uc0\u1080 \uc0\u1089 \uc0\u1082  \uc0\u1091 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1099  \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1086  \uc0\u1089 \uc0\u1086 \uc0\u1073 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 );  {\line}\uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1080 \uc0\u1079 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1100  \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1095 \uc0\u1077 \uc0\u1090 \uc0\u1099  \uc0\u1087 \uc0\u1086  \uc0\u1090 \uc0\u1072 \uc0\u1088 \uc0\u1080 \uc0\u1092 \uc0\u1072 \uc0\u1084  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1081  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1087 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1080 ;{\line}\uc0\u1047 \uc0\u1072 \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1089  \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1102 \uc0\u1097 \uc0\u1080 \uc0\u1093  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 , \uc0\u1086 \uc0\u1090 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1074  \uc0\u1073 \uc0\u1072 \uc0\u1085 \uc0\u1082  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1089 \uc0\u1072  \uc0\u1080  \uc0\u1095 \uc0\u1077 \uc0\u1082 \uc0\u1072  \uc0\u1086 \uc0\u1073  \uc0\u1086 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1077 ;{\line}\uc0\u1057 \uc0\u1086 \uc0\u1075 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1089  \uc0\u1073 \uc0\u1072 \uc0\u1085 \uc0\u1082 \uc0\u1086 \uc0\u1084  \uc0\u1091 \uc0\u1089 \uc0\u1083 \uc0\u1086 \uc0\u1074 \uc0\u1080 \uc0\u1081  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1072 \uc0\u1093 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1089 \uc0\u1072  \uc0\u1087 \uc0\u1086  \uc0\u1080 \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1077 }\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1040 \uc0\u1074 \uc0\u1075 \uc0\u1091 \uc0\u1089 \uc0\u1090  2020 \emdash  \uc0\u1071 \uc0\u1085 \uc0\u1074 \uc0\u1072 \uc0\u1088 \uc0\u1100  2022\line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  6 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\pard\intbl\itap1\sb250\par\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1054 \uc0\u1054 \uc0\u1054  \uc0\u1053 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1093 }\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1100 }\par\pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1041 \uc0\u1080 \uc0\u1079 \uc0\u1085 \uc0\u1077 \uc0\u1089 -\uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1090 \uc0\u1080 \uc0\u1082 \par}\pard\intbl\itap1\sl260\sa60{\fs18 \uc0\u1055 \uc0\u1086 \uc0\u1080 \uc0\u1089 \uc0\u1082 , \uc0\u1089 \uc0\u1073 \uc0\u1086 \uc0\u1088  \uc0\u1080  \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1091 \uc0\u1088 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1080 \uc0\u1079  \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1088 \uc0\u1099 \uc0\u1090 \uc0\u1099 \uc0\u1093  \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1095 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1074 , \uc0\u1089 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1073 \uc0\u1072 \uc0\u1079  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1080  \uc0\u1072 \uc0\u1088 \uc0\u1093 \uc0\u1080 \uc0\u1074 \uc0\u1072  \uc0\u1101 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1047 \uc0\u1072 \uc0\u1082 \uc0\u1072 \uc0\u1079 \uc0\u1095 \uc0\u1080 \uc0\u1082 \uc0\u1072 .{\line}\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1072 \uc0\u1083 \uc0\u1075 \uc0\u1086 \uc0\u1088 \uc0\u1080 \uc0\u1090 \uc0\u1084 \uc0\u1086 \uc0\u1074 , \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1091 \uc0\u1083 , \uc0\u1084 \uc0\u1072 \uc0\u1082 \uc0\u1088 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1080  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1095 \uc0\u1077 \uc0\u1090 \uc0\u1086 \uc0\u1074 .{\line}\uc0\u1055 \uc0\u1086 \uc0\u1076 \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074 : \uc0\u1080 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1094 \uc0\u1080 \uc0\u1080 , \uc0\u1084 \uc0\u1077 \uc0\u1090 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1082 \uc0\u1080 , \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1079 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sl220{\fs22\uc0\u1042 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1077 \uc0\u1077 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2018\line \uc0\u1042 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1077 \uc0\u1077 }\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  (\uc0\u1055 \uc0\u1088 \uc0\u1080 \uc0\u1074 \uc0\u1086 \uc0\u1083 \uc0\u1078 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081 ) \uc0\u1092 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090 , \uc0\u1050 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1100 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1070 \uc0\u1088 \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1091 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1094 \uc0\u1080 \uc0\u1103 , \uc0\u1043 \uc0\u1088 \uc0\u1072 \uc0\u1078 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1082 \uc0\u1086 -\uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1103 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1055 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1074 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 , \uc0\u1082 \uc0\u1091 \uc0\u1088 \uc0\u1089 \uc0\u1099 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2024}\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1048 \uc0\u1085 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088  \uc0\u1087 \uc0\u1086  \uc0\u1088 \uc0\u1091 \uc0\u1095 \uc0\u1085 \uc0\u1086 \uc0\u1084 \uc0\u1091  \uc0\u1090 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1102 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1040 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1085 \uc0\u1086 \uc0\u1084 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1085 \uc0\u1077 \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1084 \uc0\u1077 \uc0\u1088 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103  \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1074 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1077 \uc0\u1075 \uc0\u1086  \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u171 \uc0\u1059 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090  \uc0\u1048 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1089 \uc0\u187 , \uc0\u1048 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1089 , \uc0\u1058 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1097 \uc0\u1080 \uc0\u1082 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1047 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 \uc0\u1086 \uc0\u1074 }\cell\pard\intbl\itap1\sl260{\fs18 \uc0\u1056 \uc0\u1091 \uc0\u1089 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  \uc0\u1056 \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1086 \uc0\u1081 }\par \uc0\u1058 \uc0\u1072 \uc0\u1090 \uc0\u1072 \uc0\u1088 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  C2 \uc0\u8212  \uc0\u1042  \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 }}\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\pard\intbl\itap1\sb250\sl260{\fs18 {\cb5\chcfpat5\chcbpat5 \uc0\u1042 \uc0\u1099 \uc0\u1089 \uc0\u1086 \uc0\u1082 \uc0\u1072 \uc0\u1103 \~\uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1073 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 ,\~\uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1086 \uc0\u1091 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1081 \uc0\u1095 \uc0\u1080 \uc0\u1074 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 ,\~\uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1086 \uc0\u1090 \uc0\u1085 \uc0\u1072 \uc0\u1103 \~\uc0\u1088 \uc0\u1077 \uc0\u1095 \uc0\u1100 ,\~\uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1084 \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1073 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1047 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \~\uc0\u1085 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1086 -\uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1081 \~\uc0\u1073 \uc0\u1072 \uc0\u1079 \uc0\u1099 \~\uc0\u1076 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1091 \uc0\u1102 \uc0\u1097 \uc0\u1077 \uc0\u1075 \uc0\u1086 \~\uc0\u1079 \uc0\u1072 \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1072 .}  {\cb5\chcfpat5\chcbpat5 Java}  {\cb5\chcfpat5\chcbpat5 PostgreSQL}  {\cb5\chcfpat5\chcbpat5 \uc0\u1040 \uc0\u1085 \uc0\u1075 \uc0\u1083 \uc0\u1080 \uc0\u1081 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081 \~\uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1059 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 \~\uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1073 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103 \uc0\u1084 \uc0\u1080 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1041 \uc0\u1080 \uc0\u1079 \uc0\u1085 \uc0\u1077 \uc0\u1089 -\uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1052 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \~\uc0\u1073 \uc0\u1080 \uc0\u1079 \uc0\u1085 \uc0\u1077 \uc0\u1089 \~\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1086 \uc0\u1074 }  {\cb5\chcfpat5\chcbpat5 Agile}  {\cb5\chcfpat5\chcbpat5 Scrum}  {\cb5\chcfpat5\chcbpat5 \uc0\u1042 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 \~\uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1095 \uc0\u1077 \uc0\u1081 \~\uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1042 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077 \~\uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1086 \uc0\u1081 \~\uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 }  {\cb5\chcfpat5\chcbpat5 \uc0\u1055 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072 \~\uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095 \~\uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1095 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1084 }}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1044 \uc0\u1086 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1080 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1054 \uc0\u1073 \uc0\u1086  \uc0\u1084 \uc0\u1085 \uc0\u1077 }\cell\pard\intbl\itap1\sl260{\fs18 \uc0\u1041 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1077  \uc0\u1079 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  Java \uc0\u1080  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072  \uc0\u1089  \uc0\u1073 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1081  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  PostgreSQL;{\line}\uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1072 \uc0\u1074 \uc0\u1090 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1090 \uc0\u1080 \uc0\u1079 \uc0\u10