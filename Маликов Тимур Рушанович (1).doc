 \cell\row}{\footerf{\footery320 {\rtlch\fcs1 \af0\afs20 \ltrch\fcs0 \f0\fs16\cf4 \uc0\u1056 \uc0\u1077 \uc0\u1079 \uc0\u1102 \uc0\u1084 \uc0\u1077  \uc0\u1086 \uc0\u1073 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1086  24 \uc0\u1084 \uc0\u1072 \uc0\u1088 \uc0\u1090 \uc0\u1072  2026 \uc0\u1074  08:07}}}{\footer{\footery320 {\rtlch\fcs1 \af0\afs20 \ltrch\fcs0 \f0\fs16\cf4 \uc0\u1052 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1082 \uc0\u1086 \uc0\u1074  \uc0\u1058 \uc0\u1080 \uc0\u1084 \uc0\u1091 \uc0\u1088   \uc0\u8226   \uc0\u1056 \uc0\u1077 \uc0\u1079 \uc0\u1102 \uc0\u1084 \uc0\u1077  \uc0\u1086 \uc0\u1073 \uc0\u1085 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1086  24 \uc0\u1084 \uc0\u1072 \uc0\u1088 \uc0\u1090 \uc0\u1072  2026 \uc0\u1074  08:07}}}\trowd\trpaddft3\trpaddt200\cellx1800\cellx9638 \pard\intbl\sb100{ {\*\shppict{\pict\jpegblip\picwgoal1425\pichgoal1680
